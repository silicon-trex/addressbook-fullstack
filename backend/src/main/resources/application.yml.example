server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/通讯录管理系统?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: 你的数据库密码
